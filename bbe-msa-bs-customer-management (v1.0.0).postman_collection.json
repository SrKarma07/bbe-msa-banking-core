      "name": "01 - Customers",
      "item": [
        {
          "name": "List Customers (filter state=true)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Verify variables and log resolved URL",
                  "console.log('=== Variable Verification ===');",
                  "const variables = [",
                  "  { name: 'baseUrl', value: pm.variables.get('baseUrl') },",
                  "  { name: 'correlationId', value: pm.variables.get('correlationId') }",
                  "];",
                  "variables.forEach(v => {",
                  "  if (!v.value) console.warn(`⚠️ ${v.name}: NOT SET or EMPTY`);",
                  "  else console.log(`✓ ${v.name}: ${v.value}`);",
                  "});",
                  "const resolvedUrl = pm.variables.replaceIn('{{baseUrl}}/customers?page=0&size=50&state=true');",
                  "console.log('\\n=== Resolved Request URL ===');",
                  "console.log(resolvedUrl);",
                  "console.log('========================');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "pm.test('Returns array', () => pm.expect(data).to.be.an('array'));",
                  "pm.test('Each item has id + identification + state', () => {",
                  "  data.forEach(c => {",
                  "    pm.expect(c).to.have.property('id');",
                  "    pm.expect(c).to.have.property('identification');",
                  "    pm.expect(c).to.have.property('state');",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "X-Correlation-Id",
                "value": "{{correlationId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/customers?page=0&size=50&state=true",
