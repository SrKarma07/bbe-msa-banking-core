        {
          "name": "Create Customer (auto-generated identification)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Auto-generate identification/password if empty",
                  "if (!pm.collectionVariables.get('createdIdentification')) {",
                  "  const rnd = Math.floor(Math.random() * 1000000);",
                  "  pm.collectionVariables.set('createdIdentification', `EC-NEW-${Date.now()}-${rnd}`);",
                  "}",
                  "if (!pm.collectionVariables.get('createdPassword')) {",
                  "  pm.collectionVariables.set('createdPassword', `ChangeMe${Math.floor(Math.random() * 9000 + 1000)}!`);",
                  "}",
                  "console.log('createdIdentification:', pm.collectionVariables.get('createdIdentification'));",
                  "console.log('createdPassword:', pm.collectionVariables.get('createdPassword'));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const c = pm.response.json();",
                  "pm.test('Has UUID id', () => pm.expect(c.id).to.match(/^[0-9a-fA-F-]{36}$/));",
                  "pm.test('identification matches', () => pm.expect(c.identification).to.eql(pm.collectionVariables.get('createdIdentification')));",
                  "pm.collectionVariables.set('createdCustomerId', c.id);",
                  "pm.collectionVariables.set('createdCustomerName', c.name);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
