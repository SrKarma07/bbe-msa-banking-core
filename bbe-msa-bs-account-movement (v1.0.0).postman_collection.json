    {
      "name": "03 - Reports",
      "item": [
        {
          "name": "Report - Ana (2025-11-01..2026-01-31)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const r = pm.response.json();",
                  "pm.test('Has required root fields', () => {",
                  "  pm.expect(r).to.have.property('customerId');",
                  "  pm.expect(r).to.have.property('dateFrom');",
                  "  pm.expect(r).to.have.property('dateTo');",
                  "  pm.expect(r).to.have.property('accounts');",
                  "});",
                  "pm.test('accounts is array', () => pm.expect(r.accounts).to.be.an('array'));",
                  "if (r.accounts.length > 0) {",
                  "  const first = r.accounts[0];",
                  "  pm.expect(first).to.have.property('account');",
                  "  pm.expect(first).to.have.property('movements');",
                  "}",
                  "pm.test('Every movement (if any) has id', () => {",
                  "  (r.accounts || []).forEach(ai => {",
                  "    (ai.movements || []).forEach(m => pm.expect(m).to.have.property('id'));",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
